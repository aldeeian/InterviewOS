# Copy to .env.local and fill in to enable real AI features.
# Without any set, /api/copilot/suggest automatically falls back to the
# local heuristic engine in lib/copilot.ts — no key required to run the app.
# Priority when multiple are set: OpenAI > Gemini > Anthropic.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Deepgram powers live transcription (mic + shared meeting-tab audio) on the
# Live Meeting Copilot page. Without it, that page falls back to the browser's
# built-in mic-only Web Speech API. Get a key at https://console.deepgram.com
DEEPGRAM_API_KEY=
# Optional — only needed if your Deepgram account has more than one project.
DEEPGRAM_PROJECT_ID=
